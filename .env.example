# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# Postgres (ADR-02). Local dev + CI.
DATABASE_URL=postgres://fos:fos@localhost:5432/fos

# Notion adapter (ADR-05: internal-integration token, not OAuth).
FOS_NOTION_TOKEN=
# The one-time webhook verification_token (ADR-06 Finding 2), captured from
# the /notion/webhook verification handshake response. A SECRET — never log
# it. Used to HMAC-SHA256-verify the X-Notion-Signature header.
FOS_NOTION_WEBHOOK_SECRET=
# The Notion data source (database) id for the Enrollment Pipeline that
# /notion/webhook triggers a fetch-latest against (issue #39, slice 0.2f).
# Single-data-source scope for now — see notion-webhook.ts.
FOS_NOTION_ENROLLMENT_DATA_SOURCE_ID=
# Optional: the workspace_integration row id this poll runs against
# (nullable, per 0.2d's own note — acceptable if integration wiring isn't
# present yet).
FOS_NOTION_WORKSPACE_INTEGRATION_ID=

# Anthropic (ADR-07). Not needed until Phase 1 (Phase 0 uses no LLM).
ANTHROPIC_API_KEY=

# Service-account auth for the FOS API (ADR-01 shim, slice 0.1a).
# The API authenticates a single trusted service caller via this bearer token
# and binds every request to this workspace/actor. FAIL CLOSED: if the token
# or workspace id is empty, the API returns 503 and authenticates no one.
# Replaced by the ADR-01 accounts model in a later slice.
FOS_SERVICE_TOKEN=
FOS_SERVICE_WORKSPACE_ID=
FOS_SERVICE_ACTOR_ID=
